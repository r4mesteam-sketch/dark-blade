# =========================
# DATABASE
# =========================
DATABASE_URL=postgresql://darkblade_user:darkblade_password@localhost:5432/dark_blade_db

# =========================
# REDIS
# =========================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =========================
# AUTHENTICATION
# =========================
JWT_SECRET=your-super-secure-jwt-secret-key-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=dark-blade
JWT_AUDIENCE=dark-blade-users

# =========================
# APPLICATION
# =========================
NODE_ENV=development
APP_PORT=3001
FRONTEND_URL=http://localhost:3000
API_VERSION=v1

# =========================
# BITCOIN & BLOCKCHAIN
# =========================
BITCOIN_NETWORK=testnet
BITCOIN_RPC_URL=http://localhost:18332
BITCOIN_RPC_USER=bitcoin
BITCOIN_RPC_PASS=password
BLOCK_CONFIRMATIONS_REQUIRED=3
BITCOIN_TESTNET_FAUCET=https://testnet-faucet.mempool.space

# =========================
# SUBSCRIPTIONS & PAYMENTS
# =========================
SELLER_SUBSCRIPTION_PRICE_USD=50
SELLER_SUBSCRIPTION_BILLING_CYCLE=monthly
SUBSCRIPTION_GRACE_PERIOD_DAYS=3

# =========================
# EMAIL & SMTP
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@darkblade.market
SMTP_FROM_NAME=Dark Blade

# =========================
# FILE UPLOAD
# =========================
UPLOAD_MAX_FILE_SIZE=10485760
UPLOAD_ALLOWED_MIMES=image/jpeg,image/png,image/webp,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# =========================
# SECURITY
# =========================
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# =========================
# LOGGING
# =========================
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# =========================
# THIRD-PARTY SERVICES
# =========================
COINGECKO_API_URL=https://api.coingecko.com/api/v3
STRIPE_SECRET_KEY_DISABLED=
PAYPAL_API_URL_DISABLED=

# =========================
# ADMIN SETUP
# =========================
ADMIN_EMAIL=admin@darkblade.local
ADMIN_PASSWORD_TEMP=ChangeMe123!@#

# =========================
# ENCRYPTION
# =========================
ENCRYPTION_KEY=your-32-character-encryption-key-!
ENCRYPTION_ALGORITHM=aes-256-cbc
