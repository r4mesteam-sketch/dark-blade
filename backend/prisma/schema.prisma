// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  ADMIN
  SELLER
  BUYER
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  EXPIRED
  SUSPENDED
  CANCELLED
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_CONFIRMED
  PROCESSING
  PACKED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  CONFIRMING
  CONFIRMED
  FAILED
  EXPIRED
  CANCELLED
  REFUNDED
}

enum ChatMessageType {
  TEXT
  IMAGE
  FILE
  EMOJI
}

enum NotificationType {
  ORDER_CREATED
  ORDER_UPDATED
  PAYMENT_RECEIVED
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_EXPIRING
  NEW_MESSAGE
  NEW_REVIEW
  SECURITY_ALERT
  ADMIN_ANNOUNCEMENT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReportStatus {
  PENDING
  INVESTIGATING
  RESOLVED
  DISMISSED
}

enum ReportType {
  PRODUCT
  STORE
  USER
  PAYMENT
  CHAT
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model User {
  id                    String      @id @default(cuid())
  email                 String      @unique
  passwordHash          String
  firstName             String?
  lastName              String?
  role                  Role        @default(BUYER)
  avatar                String?
  bio                   String?
  emailVerified         Boolean     @default(false)
  emailVerificationToken String?
  twoFactorEnabled      Boolean     @default(false)
  twoFactorSecret       String?
  isActive              Boolean     @default(true)
  isSuspended           Boolean     @default(false)
  lastLogin             DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  deletedAt             DateTime?

  // Relationships
  seller                Seller?
  buyer                 Buyer?
  addresses             Address[]
  chatsInitiated        Chat[]      @relation("initiatedBy")
  chatsReceived         Chat[]      @relation("chatWith")
  messages              Message[]
  notifications         Notification[]
  reviews               Review[]
  ratings               Rating[]
  supportTickets        SupportTicket[]
  auditLogs             AuditLog[]
  activityLogs          ActivityLog[]
  sessions              DeviceSession[]

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model DeviceSession {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName        String
  deviceType        String    // mobile, desktop, tablet
  ipAddress         String
  userAgent         String
  isActive          Boolean   @default(true)
  lastActivityAt    DateTime  @default(now())
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([isActive])
}

model Address {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label             String?   // Home, Work, etc.
  fullName          String
  phoneNumber       String
  streetAddress     String
  city              String
  state             String
  postalCode        String
  country           String
  isDefault         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orders            Order[]

  @@index([userId])
}

// ============================================================================
// SELLER & STORE
// ============================================================================

model Seller {
  id                    String      @id @default(cuid())
  userId                String      @unique
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName          String
  businessRegistration String?
  taxId                 String?
  isVerified            Boolean     @default(false)
  verificationDate      DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  // Relationships
  store                 Store?
  subscriptions         Subscription[]

  @@index([userId])
  @@index([isVerified])
}

model Store {
  id                    String      @id @default(cuid())
  sellerId              String      @unique
  seller                Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  storeName             String
  storeSlug             String      @unique
  storeDescription      String?
  storeLogo             String?
  storeBanner           String?
  storeUrl              String?     // Custom URL
  storePolicy           String?
  isVacationMode        Boolean     @default(false)
  vacationMessage       String?
  phoneNumber           String?
  email                 String?
  followerCount         Int         @default(0)
  rating                Float       @default(0)
  totalReviews          Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  // Relationships
  products              Product[]
  orders                Order[]
  reviews               Review[]
  followers             StoreFollower[]

  @@index([storeSlug])
  @@index([isVacationMode])
}

model StoreFollower {
  id                String    @id @default(cuid())
  storeId           String
  store             Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  followerId        String
  createdAt         DateTime  @default(now())

  @@unique([storeId, followerId])
  @@index([storeId])
}

// ============================================================================
// BUYER
// ============================================================================

model Buyer {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wishlistItems     Int       @default(0)
  totalOrders       Int       @default(0)
  totalSpent        Float     @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relationships
  wishlists         Wishlist[]
  carts             CartItem[]
  orders            Order[]

  @@index([userId])
}

model Wishlist {
  id                String    @id @default(cuid())
  buyerId           String
  buyer             Buyer     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now())

  @@unique([buyerId, productId])
  @@index([buyerId])
  @@index([productId])
}

model CartItem {
  id                String    @id @default(cuid())
  buyerId           String
  buyer             Buyer     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity          Int       @default(1)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([buyerId, productId])
  @@index([buyerId])
  @@index([productId])
}

// ============================================================================
// PRODUCTS & CATEGORIES
// ============================================================================

model Category {
  id                String    @id @default(cuid())
  name              String    @unique
  slug              String    @unique
  description       String?
  image             String?
  parentId          String?
  parent            Category? @relation("subcategories", fields: [parentId], references: [id])
  isFeatured        Boolean   @default(false)
  isHidden          Boolean   @default(false)
  displayOrder      Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  subcategories     Category[]  @relation("subcategories")
  products          Product[]

  @@index([slug])
  @@index([isFeatured])
}

model Product {
  id                    String      @id @default(cuid())
  storeId               String
  store                 Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId            String
  category              Category    @relation(fields: [categoryId], references: [id])
  title                 String
  slug                  String
  description           String?
  longDescription       String?
  price                 Float
  cost                  Float?
  discountPercentage    Float?      @default(0)
  sku                   String?
  barcode               String?
  quantity              Int         @default(0)
  isDigital             Boolean     @default(false)
  isPhysical            Boolean     @default(true)
  publishedAt           DateTime?
  scheduledPublishAt    DateTime?
  isDraft               Boolean     @default(true)
  status                String      @default("draft") // draft, active, inactive
  seoTitle              String?
  seoDescription        String?
  seoKeywords           String?
  rating                Float       @default(0)
  reviewCount           Int         @default(0)
  viewCount             Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  deletedAt             DateTime?

  // Relationships
  images                ProductImage[]
  variants              ProductVariant[]
  orderItems            OrderItem[]
  reviews               Review[]
  wishlists             Wishlist[]
  cartItems             CartItem[]
  shippingProfile       ShippingProfile?

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([categoryId])
  @@index([isDraft])
  @@index([status])
}

model ProductImage {
  id                String    @id @default(cuid())
  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  url               String
  altText           String?
  displayOrder      Int       @default(0)
  createdAt         DateTime  @default(now())

  @@index([productId])
}

model ProductVariant {
  id                String    @id @default(cuid())
  productId         String
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  name              String    // Color, Size, etc.
  value             String
  sku               String?
  price             Float?
  quantity          Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  orderItems        OrderItem[]

  @@index([productId])
}

// ============================================================================
// ORDERS
// ============================================================================

model Order {
  id                    String      @id @default(cuid())
  storeId               String
  store                 Store       @relation(fields: [storeId], references: [id])
  buyerId               String
  buyer                 Buyer       @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  userId                String
  user                  User        @relation(fields: [userId], references: [id])
  shippingAddressId     String?
  shippingAddress       Address?    @relation(fields: [shippingAddressId], references: [id])
  orderNumber           String      @unique
  status                OrderStatus @default(PENDING_PAYMENT)
  subtotal              Float
  shippingCost          Float       @default(0)
  tax                   Float       @default(0)
  total                 Float
  discountAmount        Float       @default(0)
  couponCode            String?
  notes                 String?
  trackingNumber        String?
  estimatedDeliveryDate DateTime?
  actualDeliveryDate    DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  // Relationships
  items                 OrderItem[]
  payment               BitcoinTransaction?
  shippingProfile       ShippingProfile?

  @@index([storeId])
  @@index([buyerId])
  @@index([status])
}

model OrderItem {
  id                    String      @id @default(cuid())
  orderId               String
  order                 Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId             String
  product               Product     @relation(fields: [productId], references: [id])
  variantId             String?
  variant               ProductVariant? @relation(fields: [variantId], references: [id])
  quantity              Int
  unitPrice             Float
  totalPrice            Float
  createdAt             DateTime    @default(now())

  @@index([orderId])
  @@index([productId])
}

// ============================================================================
// BITCOIN & PAYMENTS
// ============================================================================

model BitcoinWallet {
  id                    String    @id @default(cuid())
  address               String    @unique
  publicKey             String
  balance               Float     @default(0)
  totalReceived         Float     @default(0)
  totalSent             Float     @default(0)
  lastSyncedAt          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  transactions          BitcoinTransaction[]

  @@index([address])
}

model BitcoinTransaction {
  id                    String      @id @default(cuid())
  walletId              String?
  wallet                BitcoinWallet? @relation(fields: [walletId], references: [id])
  orderId               String?     @unique
  order                 Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  subscriptionId        String?     @unique
  subscription          Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  transactionHash       String?     @unique
  fromAddress           String?
  toAddress             String      // Merchant receiving address
  amountBTC             Float
  amountUSD             Float
  status                PaymentStatus @default(PENDING)
  confirmations         Int         @default(0)
  requiredConfirmations Int         @default(3)
  expiresAt             DateTime?
  confirmedAt           DateTime?
  failureReason         String?
  metadata              String?     // JSON data
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([walletId])
  @@index([orderId])
  @@index([transactionHash])
  @@index([status])
}

// ============================================================================
// SUBSCRIPTIONS
// ============================================================================

model Subscription {
  id                    String      @id @default(cuid())
  sellerId              String
  seller                Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  status                SubscriptionStatus @default(ACTIVE)
  plan                  String      @default("standard") // standard, pro, enterprise
  priceUSD              Float       @default(50)
  billingCycle          String      @default("monthly") // monthly, quarterly, yearly
  startDate             DateTime
  endDate               DateTime
  renewalDate           DateTime
  gracePeriodEnd        DateTime?
  paymentMethod         String      @default("bitcoin")
  autoRenewal           Boolean     @default(true)
  invoiceCount          Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  // Relationships
  payment               BitcoinTransaction?
  invoices              SubscriptionInvoice[]

  @@index([sellerId])
  @@index([status])
  @@index([renewalDate])
}

model SubscriptionInvoice {
  id                    String      @id @default(cuid())
  subscriptionId        String
  subscription          Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceNumber         String      @unique
  amount                Float
  currency              String      @default("USD")
  status                String      @default("pending") // pending, paid, overdue, cancelled
  issuedDate            DateTime
  dueDate               DateTime
  paidDate              DateTime?
  createdAt             DateTime    @default(now())

  @@index([subscriptionId])
  @@index([status])
}

// ============================================================================
// REVIEWS & RATINGS
// ============================================================================

model Review {
  id                    String    @id @default(cuid())
  productId             String
  product               Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId               String
  store                 Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId               String?
  title                 String
  comment               String
  rating                Int       // 1-5
  isVerified            Boolean   @default(true)
  isVisible             Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  ratings               Rating[]

  @@index([productId])
  @@index([storeId])
  @@index([userId])
  @@index([rating])
}

model Rating {
  id                    String    @id @default(cuid())
  reviewId              String
  review                Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isHelpful             Boolean
  createdAt             DateTime  @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
}

// ============================================================================
// ENCRYPTED CHAT
// ============================================================================

model Chat {
  id                    String    @id @default(cuid())
  initiatedById         String
  initiatedBy           User      @relation("initiatedBy", fields: [initiatedById], references: [id], onDelete: Cascade)
  chatWithId            String
  chatWith              User      @relation("chatWith", fields: [chatWithId], references: [id], onDelete: Cascade)
  isArchived            Boolean   @default(false)
  blockedBy             String?   // userId who blocked the chat
  lastMessageAt         DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relationships
  messages              Message[]

  @@unique([initiatedById, chatWithId])
  @@index([initiatedById])
  @@index([chatWithId])
  @@index([isArchived])
}

model Message {
  id                    String      @id @default(cuid())
  chatId                String
  chat                  Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId              String
  sender                User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  messageType           ChatMessageType @default(TEXT)
  content               String      // Encrypted content
  isEncrypted           Boolean     @default(true)
  encryptionKey         String?     // IV for decryption
  isEdited              Boolean     @default(false)
  editedAt              DateTime?
  isDeleted             Boolean     @default(false)
  deletedAt             DateTime?
  isRead                Boolean     @default(false)
  readAt                DateTime?
  attachmentUrl         String?
  attachmentType        String?     // image, file, emoji
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([chatId])
  @@index([senderId])
  @@index([isRead])
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                  NotificationType
  title                 String
  message               String
  actionUrl             String?
  isRead                Boolean     @default(false)
  readAt                DateTime?
  sentViaEmail          Boolean     @default(false)
  relatedOrderId        String?
  relatedProductId      String?
  createdAt             DateTime    @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([type])
}

// ============================================================================
// SUPPORT & TICKETS
// ============================================================================

model SupportTicket {
  id                    String      @id @default(cuid())
  ticketNumber          String      @unique
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category              String      // billing, product, delivery, technical, other
  priority              SupportTicketPriority @default(MEDIUM)
  status                SupportTicketStatus @default(OPEN)
  subject               String
  description           String
  attachments           String?     // JSON array of URLs
  assignedToId          String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  resolvedAt            DateTime?

  messages              TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([priority])
}

model TicketMessage {
  id                    String    @id @default(cuid())
  ticketId              String
  ticket                SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType            String    // user, admin
  message               String
  attachments           String?   // JSON array
  createdAt             DateTime  @default(now())

  @@index([ticketId])
}

// ============================================================================
// REPORTS & MODERATION
// ============================================================================

model Report {
  id                    String      @id @default(cuid())
  reportType            ReportType
  reportedResourceId    String
  reportedBy            String
  reportReason          String
  reportDescription     String?
  status                ReportStatus @default(PENDING)
  adminNotes            String?
  attachments           String?     // JSON array
  reviewedBy            String?
  reviewedAt            DateTime?
  resolvedAt            DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([reportType])
  @@index([status])
  @@index([reportedBy])
}

// ============================================================================
// COUPONS & DISCOUNTS
// ============================================================================

model Coupon {
  id                    String    @id @default(cuid())
  code                  String    @unique
  description           String?
  discountType          String    // percentage, fixed
  discountValue         Float
  maxUses               Int?
  currentUses           Int       @default(0)
  usedByUsers           String?   // JSON array of user IDs
  minOrderValue         Float     @default(0)
  maxOrderValue         Float?
  applicableCategories  String?   // JSON array
  startDate             DateTime
  endDate               DateTime
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}

// ============================================================================
// SHIPPING
// ============================================================================

model ShippingProfile {
  id                    String    @id @default(cuid())
  productId             String    @unique
  product               Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderId               String?   @unique
  order                 Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  weight                Float?
  length                Float?
  width                 Float?
  height                Float?
  shippingClass         String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  rates                 ShippingRate[]
}

model ShippingRate {
  id                    String    @id @default(cuid())
  profileId             String
  profile               ShippingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  destination           String    // Country code or zone
  carrier               String    // DHL, FedEx, UPS, Local
  baseCost              Float
  weightCost            Float?
  estimatedDays         Int
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())

  @@index([profileId])
}

// ============================================================================
// AUDIT & ACTIVITY LOGS
// ============================================================================

model AuditLog {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action                String    // login, logout, create, update, delete
  resourceType          String    // product, order, store, user
  resourceId            String?
  changes               String?   // JSON of what changed
  ipAddress             String?
  userAgent             String?
  createdAt             DateTime  @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ActivityLog {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity              String
  details               String?   // JSON
  timestamp             DateTime  @default(now())

  @@index([userId])
  @@index([timestamp])
}

// ============================================================================
// WEBSITE SETTINGS & CONFIGURATION
// ============================================================================

model SiteSettings {
  id                    String    @id @default(cuid())
  key                   String    @unique
  value                 String
  description           String?
  category              String    // general, payment, email, security
  updatedAt             DateTime  @updatedAt
  updatedBy             String?

  @@index([category])
}
